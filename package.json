{
  "name": "atlas-ai",
  "version": "1.0.1",
  "description": "Turn any URL or bookmark into AI knowledge. Captures, classifies, and syncs skills and notes to your coding tools automatically.",
  "type": "module",
  "license": "MIT",
  "author": "Vansitha Induja",
  "homepage": "https://github.com/Vansitha/atlas#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/Vansitha/atlas.git"
  },
  "bugs": {
    "url": "https://github.com/Vansitha/atlas/issues"
  },
  "keywords": [
    "ai",
    "cli",
    "knowledge",
    "skills",
    "bookmarks",
    "url",
    "llm",
    "coding-assistant",
    "claude",
    "cursor",
    "copilot",
    "windsurf",
    "developer-tools"
  ],
  "bin": {
    "atlas": "./dist/bin/atlas.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "llms.txt"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "postbuild": "chmod +x dist/bin/atlas.js",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky",
    "prepublishOnly": "npm run build && npm test"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": "prettier --write"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@clack/prompts": "^0.9.1",
    "cheerio": "^1.0.0",
    "chokidar": "^4.0.3",
    "commander": "^13.1.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.14",
    "@vitest/coverage-v8": "^3.0.9",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  }
}
